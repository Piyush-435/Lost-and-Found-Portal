<%- include('partials/head') %>
<body>
<%- include('partials/navbar', { activePage: '' }) %>
<%- include('partials/flash') %>

<div class="form-container">
  <div class="form-header">
    <h1 class="form-title">Welcome Back!</h1>
    <p class="form-subtitle">Login to access your account</p>
  </div>

  <form action="/login" method="POST">
    <div class="form-group">
      <label class="form-label" for="email">Email Address</label>
      <input type="email" id="email" name="email" class="form-input" placeholder="Enter your email" required />
    </div>
    <div class="form-group">
      <label class="form-label" for="password">Password</label>
      <input type="password" id="password" name="password" class="form-input" placeholder="Enter your password" required />
    </div>
    <div class="form-group" style="display:flex;justify-content:space-between;align-items:center;">
      <label class="form-checkbox-label">
        <input type="checkbox" name="remember" />
        <span>Remember me</span>
      </label>
      <a href="/forgot-password" class="form-link">Forgot Password?</a>
    </div>
    <button type="submit" class="form-button btn-primary">Login to Account</button>
  </form>

  <div class="form-footer">
    Don't have an account? <a href="/register">Sign up here</a>
  </div>

 <div class="social-divider"><span>Or Continue with</span></div>
<div class="social-buttons" style="justify-content:center;">
  <button class="btn-social" style="display:flex; align-items:center; gap:10px;">
    <svg width="20" height="20" viewBox="0 0 48 48">
      <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
      <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
      <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
      <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
      <path fill="none" d="M0 0h48v48H0z"/>
    </svg>
    Continue with Google
  </button>
</div>
</div>

<script src="/js/app.js"></script>
</body>
</html>
