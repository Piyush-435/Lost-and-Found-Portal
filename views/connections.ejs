<%- include('partials/head') %>
<body>
<%- include('partials/navbar', { activePage: '' }) %>
<%- include('partials/flash') %>

<div class="dashboard-container">
  <%- include('partials/sidebar', { activeSidebar: 'connections' }) %>

  <main class="dashboard-content">

    <div class="dashboard-header">
      <div>
        <h1 class="dashboard-title">Connections</h1>
        <p style="color:var(--text-secondary);">Manage your connection requests and accepted connections</p>
      </div>
    </div>

    <% if (requests.length === 0) { %>

      <!-- empty state -->
      <div style="background:var(--bg-card);backdrop-filter:blur(20px);padding:60px 30px;border-radius:var(--radius-lg);box-shadow:0 10px 30px rgba(0,0,0,0.4);border:1px solid var(--border-primary);text-align:center;">
        <div style="font-size:64px;margin-bottom:20px;">🔗</div>
        <h3 style="margin-bottom:10px;color:var(--text-primary);">No connections yet</h3>
        <p style="color:var(--text-medium);margin-bottom:24px;">
          Connection requests will appear here after verification is passed.
        </p>
        <a href="/matches" class="btn-primary">View Matches</a>
      </div>

    <% } else { %>

      <div style="display:flex;flex-direction:column;gap:20px;">
        <% requests.forEach(request => { %>

          <div style="background:var(--bg-card);backdrop-filter:blur(20px);padding:24px;border-radius:var(--radius-lg);box-shadow:0 10px 30px rgba(0,0,0,0.4);border:1px solid var(--border-primary);">

            <!-- request header -->
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:12px;">
              <div style="display:flex;align-items:center;gap:12px;">
                <span style="font-size:32px;">
                  <%= request.status === 'accepted' ? '✅' : request.status === 'rejected' ? '❌' : '⏳' %>
                </span>
                <div>
                  <h3 style="font-size:18px;font-weight:700;color:var(--text-primary);">
                    <%= request.isIncoming ? 'Incoming Request' : 'Outgoing Request' %>
                  </h3>
                  <p style="font-size:13px;color:var(--text-tertiary);">
                    <%= new Date(request.createdAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %>
                  </p>
                </div>
              </div>

              <!-- status badge -->
              <div style="padding:6px 16px;border-radius:var(--radius-full);font-size:13px;font-weight:600;
                background:<%= request.status === 'accepted' ? 'rgba(16,185,129,0.15)' : request.status === 'rejected' ? 'rgba(239,68,68,0.15)' : 'rgba(245,158,11,0.15)' %>;
                color:<%= request.status === 'accepted' ? '#10b981' : request.status === 'rejected' ? '#ef4444' : '#f59e0b' %>;
                border:1px solid <%= request.status === 'accepted' ? 'rgba(16,185,129,0.4)' : request.status === 'rejected' ? 'rgba(239,68,68,0.4)' : 'rgba(245,158,11,0.4)' %>;">
                <%= request.status === 'accepted' ? '✅ Accepted' : request.status === 'rejected' ? '❌ Rejected' : '⏳ Pending' %>
              </div>
            </div>

            <!-- item names involved -->
            <% if (request.match) { %>
              <div style="display:flex;gap:12px;margin-bottom:20px;flex-wrap:wrap;">
                <div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);padding:10px 16px;border-radius:var(--radius-md);font-size:14px;">
                  <span style="color:#ef4444;font-weight:600;">LOST</span>
                  <span style="color:var(--text-primary);margin-left:8px;"><%= request.match.lostItemName %></span>
                </div>
                <div style="display:flex;align-items:center;font-size:18px;">🔗</div>
                <div style="background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2);padding:10px 16px;border-radius:var(--radius-md);font-size:14px;">
                  <span style="color:#10b981;font-weight:600;">FOUND</span>
                  <span style="color:var(--text-primary);margin-left:8px;"><%= request.match.foundItemName %></span>
                </div>
              </div>
            <% } %>

            <!-- accepted — show opposite user profile + gmail button -->
            <% if (request.status === 'accepted' && request.oppositeUser) { %>
              <div style="background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.3);border-left:4px solid #10b981;padding:20px;border-radius:var(--radius-md);margin-bottom:16px;">
                <p style="font-weight:600;color:#10b981;margin-bottom:16px;">
                  🎉 Connection approved! You can now connect through Gmail.
                </p>

                <!-- opposite user profile -->
                <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px;">
                  <div style="font-size:40px;"><%= request.oppositeUser.avatar || '👤' %></div>
                  <div>
                    <p style="font-weight:700;font-size:16px;color:var(--text-primary);margin:0;">
                      <%= request.oppositeUser.name %>
                    </p>
                    <p style="color:var(--text-secondary);font-size:14px;margin:4px 0 0;">
                      📧 <%= request.oppositeUser.email %>
                    </p>
                    <% if (request.oppositeUser.phone) { %>
                      <p style="color:var(--text-secondary);font-size:14px;margin:4px 0 0;">
                        📱 <%= request.oppositeUser.phone %>
                      </p>
                    <% } %>
                  </div>
                </div>

                <!-- gmail compose button -->
                <%
                  const subject = encodeURIComponent('Lost & Found - Item Connection');
                  const body    = encodeURIComponent(
                    'Hi ' + request.oppositeUser.name + ',\n\n' +
                    'I am contacting you regarding a lost and found item match on our portal.\n\n' +
                    'Lost Item: ' + (request.match ? request.match.lostItemName : '') + '\n' +
                    'Found Item: ' + (request.match ? request.match.foundItemName : '') + '\n\n' +
                    'Please let me know a convenient time to connect.\n\n' +
                    'Regards,\n' + currentUser.name
                  );
                  const gmailLink = 'https://mail.google.com/mail/?view=cm&to=' + request.oppositeUser.email + '&su=' + subject + '&body=' + body;
                %>
                <a href="<%= gmailLink %>" target="_blank" class="btn-primary" style="display:inline-flex;align-items:center;gap:8px;text-decoration:none;">
                  <span>📧</span> Connect via Gmail
                </a>
              </div>

            <% } else if (request.status === 'rejected') { %>
              <div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);padding:16px;border-radius:var(--radius-md);margin-bottom:16px;">
                <p style="color:#ef4444;font-size:14px;margin:0;">
                  ❌ <%= request.isIncoming ? 'You rejected this connection request.' : 'Your connection request was rejected by the other user.' %>
                </p>
              </div>

            <% } else if (request.status === 'pending' && request.isIncoming) { %>
              <!-- incoming pending — show accept/reject buttons -->
              <div style="display:flex;gap:12px;">
                <form action="/connections/<%= request.id %>/accept" method="POST">
                  <button type="submit" class="btn-primary" style="border:none;cursor:pointer;">
                    ✅ Accept
                  </button>
                </form>
                <form action="/connections/<%= request.id %>/reject" method="POST">
                  <button type="submit" class="btn-secondary" style="border:none;cursor:pointer;color:var(--danger-color);">
                    ❌ Reject
                  </button>
                </form>
              </div>

            <% } else if (request.status === 'pending' && !request.isIncoming) { %>
              <!-- outgoing pending — show waiting message -->
              <p style="color:var(--text-secondary);font-size:14px;">
                ⏳ Waiting for the other user to accept your request.
              </p>
            <% } %>

          </div>

        <% }) %>
      </div>

    <% } %>

  </main>
</div>

<%- include('partials/footer') %>
<script src="/js/app.js"></script>
</body>
</html>