<%- include('partials/head') %>
<body>
<%- include('partials/navbar', { activePage: 'dashboard' }) %>
<%- include('partials/flash') %>

<div class="dashboard-container">
  <%- include('partials/sidebar', { activeSidebar: 'dashboard' }) %>

  <main class="dashboard-content">
    <div class="dashboard-header">
      <div>
        <h1 class="dashboard-title">Welcome Back, <%= currentUser.name %>!</h1>
        <p style="color:var(--text-secondary);">Here's what's happening with your items</p>
      </div>
      <div class="dashboard-actions">
        <a href="/report-lost"  class="btn-primary">+ Report Lost</a>
        <a href="/report-found" class="btn-secondary">+ Report Found</a>
      </div>
    </div>

    <!-- Verification Alert -->
    <% if (!currentUser.emailVerified) { %>
      <div style="display:block;margin-bottom:30px;background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.3);border-left:4px solid var(--warning-color);padding:20px 24px;border-radius:var(--radius-lg);">
        <div style="display:flex;align-items:center;gap:16px;">
          <span style="font-size:32px;">⚠️</span>
          <div style="flex:1;">
            <h3 style="font-size:18px;margin-bottom:6px;color:var(--text-primary);">Verification Required</h3>
            <p style="color:var(--text-secondary);font-size:14px;">
              Please verify your email to report items.
              <a href="/profile" style="color:var(--primary-light);font-weight:600;">Verify Now →</a>
            </p>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Stats Cards -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon primary">📱</div>
        <div class="stat-info">
          <h3><%= stats.lostCount %></h3>
          <p>Lost Items Reported</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon success">✨</div>
        <div class="stat-info">
          <h3><%= stats.foundCount %></h3>
          <p>Found Items Reported</p>
        </div>
      </div>
      <!-- updated to use real match count from DB -->
      <div class="stat-card">
        <div class="stat-icon warning">🎯</div>
        <div class="stat-info">
          <h3><%= stats.matchCount %></h3>
          <p>Active Matches</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon primary">✅</div>
        <div class="stat-info">
          <h3><%= stats.resolved %></h3>
          <p>Items Recovered</p>
        </div>
      </div>
    </div>

    <!-- Recent Activity - now uses real data -->
    <div style="background:var(--bg-card);backdrop-filter:blur(20px);padding:30px;border-radius:var(--radius-lg);box-shadow:0 10px 30px rgba(0,0,0,0.4);border:1px solid var(--border-primary);margin-bottom:30px;">
      <h2 style="font-size:24px;font-weight:700;margin-bottom:24px;color:var(--text-primary);">Recent Activity</h2>
      <div style="display:flex;flex-direction:column;gap:20px;">

        <!-- show match activity if matches exist -->
        <% if (stats.matchCount > 0) { %>
          <div style="display:flex;gap:16px;padding:16px;background:rgba(139,92,246,0.1);border-radius:var(--radius-md);border:1px solid var(--border-primary);">
            <div style="font-size:32px;">🎯</div>
            <div style="flex:1;">
              <div style="display:flex;justify-content:space-between;margin-bottom:4px;">
                <strong style="color:var(--text-primary);">Possible match found!</strong>
              </div>
              <p style="color:var(--text-secondary);font-size:14px;">
                You have <%= stats.matchCount %> potential <%= stats.matchCount === 1 ? 'match' : 'matches' %> waiting for review.
                <a href="/matches" style="color:var(--primary-light);font-weight:600;">View Matches →</a>
              </p>
            </div>
          </div>
        <% } %>

        <!-- show recently reported items -->
        <% if (userItems.length > 0) { %>
          <% userItems.slice(0, 2).forEach(item => { %>
            <div style="display:flex;gap:16px;padding:16px;background:rgba(<%= item.type === 'lost' ? '239,68,68' : '16,185,129' %>,0.08);border-radius:var(--radius-md);border:1px solid var(--border-primary);">
              <div style="font-size:32px;"><%= item.icon %></div>
              <div style="flex:1;">
                <div style="display:flex;justify-content:space-between;margin-bottom:4px;">
                  <strong style="color:var(--text-primary);">
                    <%= item.type === 'lost' ? 'Lost item reported' : 'Found item reported' %>
                  </strong>
                  <span style="font-size:14px;color:var(--text-tertiary);">
                    <%= new Date(item.createdAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %>
                  </span>
                </div>
                <p style="color:var(--text-secondary);font-size:14px;">
                  <%= item.name %> — <%= item.location %>
                  <a href="/items/<%= item.id %>" style="color:var(--primary-light);font-weight:600;margin-left:8px;">View →</a>
                </p>
              </div>
            </div>
          <% }) %>
        <% } %>

        <!-- always show welcome/member since -->
        <div style="display:flex;gap:16px;padding:16px;background:rgba(16,185,129,0.1);border-radius:var(--radius-md);border:1px solid var(--border-primary);">
          <div style="font-size:32px;">✅</div>
          <div style="flex:1;">
            <div style="display:flex;justify-content:space-between;margin-bottom:4px;">
              <strong style="color:var(--text-primary);">Welcome to Lost & Found!</strong>
              <span style="font-size:14px;color:var(--text-tertiary);">
                Member since <%= new Date(currentUser.memberSince || currentUser.createdAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %>
              </span>
            </div>
            <p style="color:var(--text-secondary);font-size:14px;">Start by reporting a lost or found item to help the community.</p>
          </div>
        </div>

      </div>
    </div>

    <!-- My Recent Items -->
    <div style="background:var(--bg-card);backdrop-filter:blur(20px);padding:30px;border-radius:var(--radius-lg);box-shadow:0 10px 30px rgba(0,0,0,0.4);border:1px solid var(--border-primary);">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
        <h2 style="font-size:24px;font-weight:700;color:var(--text-primary);">My Recent Items</h2>
        <a href="/my-items" style="color:var(--primary-light);font-weight:600;">View All →</a>
      </div>

      <% if (userItems.length === 0) { %>
        <div style="text-align:center;padding:60px 20px;">
          <div style="font-size:64px;margin-bottom:20px;">📭</div>
          <h3 style="margin-bottom:10px;">No items reported yet</h3>
          <p style="color:var(--text-medium);margin-bottom:24px;">Start by reporting a lost or found item</p>
          <a href="/report-lost" class="btn-primary">Report Your First Item</a>
        </div>
      <% } else { %>
        <div class="items-grid" id="dashboardItems">
          <% userItems.forEach(item => { %>
            <div class="item-card" data-id="<%= item.id %>">
              <div class="item-image"><%= item.icon %></div>
              <div class="item-content">
                <div class="item-header">
                  <div><h3 class="item-title"><%= item.name %></h3></div>
                  <span class="item-badge <%= item.type %>"><%= item.type === 'lost' ? 'Lost' : 'Found' %></span>
                </div>
                <div class="item-meta">
                  <div class="meta-item"><span class="meta-icon">📍</span><span><%= item.location %></span></div>
                  <div class="meta-item">
                    <span class="meta-icon">📅</span>
                    <span><%= new Date(item.createdAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %></span>
                  </div>
                </div>
                <p class="item-description"><%= item.description.length > 80 ? item.description.substring(0,80)+'...' : item.description %></p>
                <div class="item-footer">
                  <a href="/items/<%= item.id %>" class="btn-primary">View</a>
                  <% if (item.status === 'active') { %>
                    <a href="/items/<%= item.id %>/edit" class="btn-secondary">✏️ Edit</a>
                  <% } %>
                  <% if (item.status === 'active') { %>
                    <form action="/items/<%= item.id %>/resolve" method="POST" style="display:inline;">
                      <button type="submit" class="btn-secondary" style="cursor:pointer;border:none;">✅ Resolve</button>
                    </form>
                  <% } %>
                  <form action="/items/<%= item.id %>/delete" method="POST" style="display:inline;"
                        onsubmit="return confirm('Delete this item?')">
                    <button type="submit" class="btn-secondary" style="cursor:pointer;border:none;color:var(--danger-color);">🗑</button>
                  </form>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </main>
</div>

<%- include('partials/footer') %>
<script src="/js/app.js"></script>
</body>
</html>