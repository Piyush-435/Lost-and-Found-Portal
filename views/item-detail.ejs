<%- include('partials/head') %>
<body>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<!-- defines a section for displaying details -->
<section style="padding:120px 20px 80px; background:var(--bg-gray); min-height:100vh;">
  <div class="container" style="max-width:700px;">
    <a href="/browse" style="color:var(--text-medium); text-decoration:none; display:inline-flex; align-items:center; gap:8px; margin-bottom:32px;">
      ← Back to Browse
    </a>

    <!-- A styled card holding the item information -->
    <div class="auth-card">

      <!-- Header -->
      <!-- Uses Flexbox layout to arrange elements horizontally -->
      <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:24px; flex-wrap:wrap; gap:16px;">
        <div style="display:flex; align-items:center; gap:16px;">

          <!-- displays item icon -->
          <div style="font-size:56px;"><%= item.icon %></div>
          <div>
            <!-- displays name -->
            <h1 style="font-size:28px; font-weight:700; margin-bottom:8px;"><%- item.name %></h1>
            <!-- displays item type -->
            <span class="item-badge <%= item.type %>"><%= item.type === 'lost' ? 'Lost' : 'Found' %></span>
            <!-- shows status -->
            <span class="item-badge" style="margin-left:8px; background:rgba(100,100,100,0.2); color:var(--text-medium);"><%= item.status %></span>
          </div>
        </div>
      </div>

      <!-- Details Grid - creates two column layout -->
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:24px;">
        <div class="detail-block">
          <span style="color:var(--text-medium); font-size:13px;">📍 Location</span>
          <!-- displays location -->
          <p style="margin:4px 0 0; font-weight:500;"><%- item.location %></p>
        </div>
        <div class="detail-block">
          <span style="color:var(--text-medium); font-size:13px;">📅 Date</span>
          <p style="margin:4px 0 0; font-weight:500;">
            <!-- Converts stored date to readable format e.g. 2026-03-10 to March 10, 2026 -->
            <%= new Date(item.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %>
            <%= item.time ? 'at ' + item.time : '' %>
          </p>
        </div>
        <!-- shows category -->
        <div class="detail-block">
          <span style="color:var(--text-medium); font-size:13px;">📂 Category</span>
          <p style="margin:4px 0 0; font-weight:500; text-transform:capitalize;"><%= item.category %></p>
        </div>
        <!-- shows contact method -->
        <div class="detail-block">
          <span style="color:var(--text-medium); font-size:13px;">📞 Contact via</span>
          <p style="margin:4px 0 0; font-weight:500; text-transform:capitalize;"><%= item.contactMethod %></p>
        </div>
        <!-- if reward exists, show it -->
        <% if (item.reward && parseFloat(item.reward) > 0) { %>
          <div class="detail-block">
            <span style="color:var(--text-medium); font-size:13px;">💰 Reward</span>
            <p style="margin:4px 0 0; font-weight:500; color:#22c55e;">$<%= parseFloat(item.reward).toFixed(2) %></p>
          </div>
        <% } %>
        <!-- If the item is found, show where it is kept -->
        <% if (item.currentLocation) { %>
          <div class="detail-block">
            <span style="color:var(--text-medium); font-size:13px;">📦 Item currently at</span>
            <!-- Replace - with spaces -->
            <p style="margin:4px 0 0; font-weight:500; text-transform:capitalize;"><%= item.currentLocation.replace(/-/g, ' ') %></p>
          </div>
        <% } %>
      </div>

      <!-- Description -->
      <div style="margin-bottom:28px;">
        <h3 style="font-size:16px; font-weight:600; margin-bottom:8px; color:var(--text-medium);">Description</h3>
        <p style="line-height:1.7;"><%- item.description %></p>
      </div>

      <!-- Reporter - shows reporter details -->
      <div style="border-top:1px solid var(--border-primary); padding-top:20px; margin-bottom:24px;">
        <h3 style="font-size:16px; font-weight:600; margin-bottom:12px; color:var(--text-medium);">Reported by</h3>
        <div style="display:flex; align-items:center; gap:12px;">
          <div style="font-size:32px;"><%= item.user ? (item.user.avatar || '👤') : '👤' %></div>
          <div>
            <p style="font-weight:600; margin:0;"><%- item.userName %></p>
            <p style="color:var(--text-medium); font-size:14px; margin:4px 0 0;">
              <!-- If memberSince exists use that, ELSE use account createdAt -->
              Member since <%= item.user ? new Date(item.user.memberSince || item.user.createdAt).getFullYear() : 'N/A' %>
            </p>
          </div>
        </div>
      </div>

      <!-- CTA - if user is logged in and user is NOT the item owner then show this -->
      <!-- ✅ MySQL: use .id instead of ._id -->
      <% if (isLoggedIn && currentUser.id !== item.userId) { %>
        <div style="display:flex; gap:12px; flex-wrap:wrap;">
          <button class="btn-primary" style="flex:1; padding:14px; border:none; cursor:pointer; font-size:16px;"
                  onclick="alert('Messaging feature coming soon! Contact via: <%= item.contactMethod %>')">
            <%= item.type === 'lost' ? '🙋 I Found This Item' : '📬 This is Mine!' %>
          </button>
        </div>
      <!-- otherwise show login prompt -->
      <% } else if (!isLoggedIn) { %>
        <a href="/login" class="btn-primary" style="display:block; text-align:center; padding:14px; font-size:16px;">
          Login to Contact Reporter
        </a>
      <% } %>

    </div>
  </div>
</section>

<!-- integrate footer -->
<%- include('partials/footer') %>
<script src="/js/app.js"></script>
</body>
</html>
